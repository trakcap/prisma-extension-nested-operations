{
  "name": "@trakcap/prisma-extension-nested-operations",
  "version": "1.0.0",
  "description": "Utils for creating Prisma client extensions with nested operations",
  "author": "Olivier Wilkinson",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/trakcap/prisma-extension-nested-operations.git"
  },
  "engines": {
    "node": "~24.13.0"
  },
  "packageManager": "yarn@4.13.0",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "prepare": "/bin/sh -c 'if type git >/dev/null 2>&1; then git config core.hooksPath .git-hooks; else true; fi'",
    "test:unit": "prisma generate && vitest run test/unit",
    "test:e2e": "./test/scripts/run-with-postgres.sh vitest run test/e2e",
    "test": "./test/scripts/run-with-postgres.sh vitest run",
    "lint": "biome check",
    "lint:fix": "biome check --fix",
    "lint:ci": "biome ci --reporter=github",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json"
  },
  "dependencies": {
    "@open-draft/deferred-promise": "^3.0.0",
    "es-toolkit": "^1.45.1"
  },
  "peerDependencies": {
    "@prisma/client": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@faker-js/faker": "^10.4.0",
    "@prisma/client": "^5.0.0",
    "@types/node": "^24.12.0",
    "prisma": "^5.0.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
